NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Apenas no servidor (criação de usuários pelo painel Super Admin). Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Cron (ex.: Vercel): rota GET /api/cron/assinaturas-expiracao — envie Authorization: Bearer <valor>
CRON_SECRET=YOUR_CRON_SECRET

# Opcional: lembrete de cobrança na renovação (e-mail via Resend)
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=BarberTool <noreply@seudominio.com>
